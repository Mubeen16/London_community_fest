# Copy to .env.local and adjust values.
# Restart `npm run dev` after changing env vars.

# Django API base URL (used by Next.js rewrites in next.config.ts).
# Local: run the backend on port 8000, then use:
API_URL=http://127.0.0.1:8000

# Production (Vercel): set API_URL in Project → Settings → Environment Variables
# to your deployed API, e.g. https://your-app.up.railway.app

# Optional — only if the browser must call the API on another origin directly
# (skips the /api proxy; Django must allow CORS for your site URL).
# NEXT_PUBLIC_API_URL=

# Google Apps Script (server-only — do NOT use NEXT_PUBLIC_ prefix).
# Forms call /api/waitlist, /api/sponsor-enquiry, and /api/vendor-enquiry.
# Deploy each script from scripts/*.gs → New deployment → Web app → Anyone.
# Temporary until Django backend is hosted.
WAITLIST_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbxH1xEcB_2KpsDtUdctf5WRVOqRT-IIAulq81dVIOidAWS8C_Bc_JuYgqEvwZV83H0ZEg/exec
SPONSORS_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbxTYtvgVOdRR7sCG0n6zZ_y2QrLQH8tJXY0P0V83BhKQYzg61dr-qBFQauH9dlVzScsgQ/exec
VENDORS_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbwEhqoyzg8BRz_cG3YDUcz1tLXiHuAqGH_XOo0fveeAGSC61OPJiJQiwMBFmHSLi0-M/exec
